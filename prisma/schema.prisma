generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ── 품목 카테고리 ──
model ItemCategory {
  id       Int    @id @default(autoincrement())
  name     String @unique
  parentId Int?   @map("parent_id")

  parent   ItemCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")
  items    Item[]

  @@map("item_category")
}

// ── 위치/창고 ──
model Location {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  address String?

  inventoryTxs InventoryTx[]
  targetLogs   TargetLog[]
  chamberSlots ChamberSlot[]
  aldLogDetails AldLogDetail[]

  @@map("location")
}

// ── 거래 목적 ──
model TxReason {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  inventoryTxs InventoryTx[]
  barcodeScan  BarcodeScan[]

  @@map("tx_reason")
}

// ── 거래처 ──
model Partner {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  managerName String? @map("manager_name")
  contact     String?
  email       String?
  isActive   Boolean  @default(true) @map("is_active")

  inventoryTxs InventoryTx[]

  @@map("partner")
}

// ── 사용자 ──
model User {
  id           Int     @id @default(autoincrement())
  name         String
  email        String? @unique
  role         String? // admin / viewer / operator
  isActive     String  @default("Y") @map("is_active") // Y | N
  permission      UserTabPermission?
  inventoryTxs    InventoryTx[]
  targetLogs      TargetLog[]
  barcodeScans    BarcodeScan[]
  chamberSlots    ChamberSlot[]
  activityLogs    ActivityLog[]
  aldPortSlots    AldPortSlot[]

  @@map("user")
}

// ── 탭 권한 ──
model UserTabPermission {
  userId                  Int    @id @map("user_id")
  canViewMain             String @default("Y") @map("can_view_main")
  canViewStatus           String @default("Y") @map("can_view_status")
  canViewPeriod           String @default("Y") @map("can_view_period")
  canViewUserPerm         String @default("N") @map("can_view_user_perm")
  canViewTargetUsage      String @default("Y") @map("can_view_target_usage")
  canViewBarcode          String @default("Y") @map("can_view_barcode")
  canViewBarcodeCreatePrint String @default("Y") @map("can_view_barcode_create_print")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_tab_permission")
}

// ── 품목 마스터 ──
model Item {
  id           Int    @id @default(autoincrement())
  categoryId   Int    @map("category_id")
  code         String @unique
  name         String
  unit         String?
  minStockQty  Int    @default(0) @map("min_stock_qty")
  note         String?

  category     ItemCategory  @relation(fields: [categoryId], references: [id])
  waferSpec    WaferSpec?
  targetSpec   TargetSpec?
  barcodes     Barcode[]
  targetUnits  TargetUnit[]
  inventoryTxs InventoryTx[]
  isActive   Boolean  @default(true) @map("is_active")

  @@map("item")
}

// ── 웨이퍼 스펙 (item 1:1) ──
model WaferSpec {
  itemId        Int     @id @map("item_id")
  diameterInch  Int     @map("diameter_inch")
  waferType     String? @map("wafer_type")    // P, P+, N, Metal 등
  dopant        String?
  grade         String?                        // Test, Prime, Monitor
  thicknessNote String? @map("thickness_note")
  resistivity   String?
  orientation   String?                        // 1-0-0, 1-1-1
  surface       String?                        // SSP, DSP
  oxidation     String?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("wafer_spec")
}

// ── 타겟 스펙 (item 1:1) ──
model TargetSpec {
  itemId        Int      @id @map("item_id")
  diameterInch  Int      @map("diameter_inch")
  thicknessInch Decimal? @map("thickness_inch") @db.Decimal(5, 3)
  materialCode  String   @map("material_code")  // AU, SI, SIO2, ATC 등
  purity        Decimal? @db.Decimal(6, 3)
  hasCopper     String?  @map("has_copper")      // Y | N

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("target_spec")
}

// ── 타겟 개별 단위 ──
model TargetUnit {
  id         Int       @id @default(autoincrement())
  itemId     Int       @map("item_id")
  status     String    @default("미사용") // 미사용 | 사용중 | 폐기 | 판매완료
  category   String    @default("sputter") // sputter | ald
  createdAt  DateTime  @default(now()) @map("created_at") @db.Date
  disposedAt DateTime? @map("disposed_at") @db.Date
  note       String?

  item            Item             @relation(fields: [itemId], references: [id])
  barcodes        Barcode[]
  inventoryTxs    InventoryTx[]
  targetLogs      TargetLog[]
  chamberSlot     ChamberSlot?
  aldCanisterSpec AldCanisterSpec?
  aldPortSlot     AldPortSlot?

  @@map("target_unit")
}

// ── 타겟 사용 이력 ──
model TargetLog {
  id           Int      @id @default(autoincrement())
  targetUnitId Int      @map("target_unit_id")
  logType      String   @map("log_type")  // 측정 | 폐기
  weight       Decimal? @db.Decimal(10, 3)
  locationId   Int?     @map("location_id")
  reason       String?
  userId       Int?     @map("user_id")
  loggedAt     DateTime @default(now()) @map("logged_at")

  targetUnit   TargetUnit    @relation(fields: [targetUnitId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  aldLogDetail AldLogDetail?

  @@map("target_log")
}

// ── 바코드 시퀀스 ──
model BarcodeSeq {
  prefix String @id
  lastNo Int    @default(0) @map("last_no")

  @@map("barcode_seq")
}

// ── 바코드 ──
model Barcode {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  itemId       Int?    @map("item_id")
  targetUnitId Int?    @unique @map("target_unit_id")
  isActive     String  @default("Y") @map("is_active")
  memo         String? @map("memo")

  item         Item?         @relation(fields: [itemId], references: [id])
  targetUnit   TargetUnit?   @relation(fields: [targetUnitId], references: [id])
  inventoryTxs InventoryTx[]
  barcodeScans BarcodeScan[]

  @@map("barcode")
}

// ── 재고 거래 이력 ──
model InventoryTx {
  id           Int      @id @default(autoincrement())
  txNo         String?  @unique @map("tx_no")
  txDate       DateTime @default(now()) @map("tx_date") @db.Date
  txType       String   @map("tx_type")    // 입고 | 불출 | 출고
  itemId       Int      @map("item_id")
  targetUnitId Int?     @map("target_unit_id")
  qty          Int
  unitPrice    Decimal? @map("unit_price") @db.Decimal(15, 2)
  amount       Decimal? @db.Decimal(15, 2)
  partnerId    Int?     @map("partner_id")
  txReasonId   Int?     @map("tx_reason_id")
  locationId   Int      @map("location_id")
  userId       Int?     @map("user_id")
  memo         String?
  refTxNo      String?  @map("ref_tx_no")
  barcodeId    Int?     @map("barcode_id")
  currency     String?  @default("KRW")
  exchangeRateAtEntry Decimal? @map("exchange_rate_at_entry") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  item       Item       @relation(fields: [itemId], references: [id])
  targetUnit TargetUnit? @relation(fields: [targetUnitId], references: [id])
  partner    Partner?   @relation(fields: [partnerId], references: [id])
  txReason   TxReason?  @relation(fields: [txReasonId], references: [id])
  location   Location   @relation(fields: [locationId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
  barcode    Barcode?   @relation(fields: [barcodeId], references: [id])
  barcodeScans BarcodeScan[]

  @@map("inventory_tx")
}

// ── 바코드 스캔 이력 ──
model BarcodeScan {
  id            Int      @id @default(autoincrement())
  barcodeId     Int      @map("barcode_id")
  scanTime      DateTime @default(now()) @map("scan_time")
  opType        String?  @map("op_type")   // 출고 | 불출
  txReasonId    Int?     @map("tx_reason_id")
  userId        Int?     @map("user_id")
  qty           Int
  inventoryTxId Int?     @map("inventory_tx_id")

  barcode     Barcode      @relation(fields: [barcodeId], references: [id])
  txReason    TxReason?    @relation(fields: [txReasonId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  inventoryTx InventoryTx? @relation(fields: [inventoryTxId], references: [id])

  @@map("barcode_scan")
}

// ── 챔버 슬롯 현황 ──
model ChamberSlot {
  id           Int         @id @default(autoincrement())
  locationId   Int         @map("location_id")
  targetUnitId Int?        @unique @map("target_unit_id")
  loadedAt     DateTime?   @map("loaded_at")
  updatedById  Int?        @map("updated_by_id")
  note         String?

  location     Location    @relation(fields: [locationId], references: [id])
  targetUnit   TargetUnit? @relation(fields: [targetUnitId], references: [id])
  updatedBy    User?       @relation(fields: [updatedById], references: [id])

  @@map("chamber_slot")
}

// ── 활동 로그 ──
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String   // CREATE, UPDATE, DELETE
  tableName String   @map("table_name")
  recordId  Int      @map("record_id")
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_log")
}

// ── 앱 설정 (범용 키-값) ──
model AppSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_setting")
}

// ── ALD Canister 전용 메타 ──
model AldCanisterSpec {
  targetUnitId       Int      @id @map("target_unit_id")
  tareWeight         Decimal  @map("tare_weight") @db.Decimal(10, 3)
  materialName       String?  @map("material_name")
  initialGrossWeight Decimal? @map("initial_gross_weight") @db.Decimal(10, 3)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  targetUnit TargetUnit @relation(fields: [targetUnitId], references: [id], onDelete: Cascade)

  @@map("ald_canister_spec")
}

// ── ALD 측정 로그 상세 (target_log 1:1 확장) ──
model AldLogDetail {
  id                   Int      @id @default(autoincrement())
  targetLogId          Int      @unique @map("target_log_id")
  logSubType           String?  @map("log_sub_type")           // 측정 | 충진 | 폐기
  materialName         String?  @map("material_name")
  grossWeight          Decimal? @map("gross_weight")           @db.Decimal(10, 3)
  tareWeight           Decimal? @map("tare_weight")            @db.Decimal(10, 3)
  measureWeight        Decimal? @map("measure_weight")         @db.Decimal(10, 3)
  cumulativeCycle      Int?     @map("cumulative_cycle")
  cycleDelta           Int?     @map("cycle_delta")
  consumptionPerCycle  Decimal? @map("consumption_per_cycle")  @db.Decimal(10, 5)
  remainPercent        Decimal? @map("remain_percent")         @db.Decimal(5, 2)
  estimatedRemainCycle Int?     @map("estimated_remain_cycle")
  locationId           Int?     @map("location_id")

  targetLog TargetLog @relation(fields: [targetLogId], references: [id], onDelete: Cascade)
  location  Location? @relation(fields: [locationId], references: [id])

  @@map("ald_log_detail")
}

// ── ALD 장비 포트별 Canister 현황 ──
model AldPortSlot {
  id            Int       @id @default(autoincrement())
  equipmentName String    @map("equipment_name")
  portNumber    Int       @map("port_number")
  targetUnitId  Int?      @unique @map("target_unit_id")
  loadedAt      DateTime? @map("loaded_at")
  updatedById   Int?      @map("updated_by_id")
  note          String?

  targetUnit TargetUnit? @relation(fields: [targetUnitId], references: [id], onDelete: SetNull)
  updatedBy  User?       @relation(fields: [updatedById], references: [id])

  @@unique([equipmentName, portNumber])
  @@map("ald_port_slot")
}
