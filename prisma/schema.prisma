generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── 사용자 ──
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   @default("employee") // admin | employee
  isActive  Boolean  @default(true) @map("is_active")
  googleId  String?  @map("google_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  permissions   UserPermission[]
  inventoryTxs  InventoryTx[]
  auditLogs     AuditLog[]
  attendances   Attendance[]
  notices       Notice[]

  @@map("user")
}

// ── 사용자 권한 ──
model UserPermission {
  id       Int     @id @default(autoincrement())
  userId   Int     @map("user_id")
  resource String  // inventory, status, period, target, barcode, barcode_create, admin
  canView  Boolean @default(true) @map("can_view")
  canEdit  Boolean @default(false) @map("can_edit")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource])
  @@map("user_permission")
}

// ── 품목 카테고리 ──
model ItemCategory {
  id         Int    @id @default(autoincrement())
  name       String @unique
  codePrefix String? @map("code_prefix")
  sortOrder  Int    @default(0) @map("sort_order")

  items Item[]

  @@map("item_category")
}

// ── 품목 ──
model Item {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("category_id")
  code       String   @unique
  name       String
  unit       String?
  spec       String?
  note       String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  category     ItemCategory  @relation(fields: [categoryId], references: [id])
  barcodes     Barcode[]
  targetUnits  TargetUnit[]
  inventoryTxs InventoryTx[]

  @@map("item")
}

// ── 거래처 / 불출처 ──
model Partner {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String   @default("vendor") // vendor | disburse
  managerName String?  @map("manager_name")
  contact     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  inventoryTxs InventoryTx[]

  @@map("partner")
}

// ── 타겟 유닛 (타겟 개별 관리) ──
model TargetUnit {
  id           Int      @id @default(autoincrement())
  itemId       Int?     @map("item_id")
  materialName String?  @map("material_name")
  purity       String?
  hasCopper    String?  @map("has_copper") // 유 | 무 | 선택
  status       String   @default("available") // available | using | disposed
  createdAt    DateTime @default(now()) @map("created_at")

  item         Item?         @relation(fields: [itemId], references: [id])
  barcodes     Barcode[]
  inventoryTxs InventoryTx[]
  targetLogs   TargetLog[]

  @@map("target_unit")
}

// ── 바코드 ──
model Barcode {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  itemId       Int?     @map("item_id")
  targetUnitId Int?     @map("target_unit_id")
  isActive     Boolean  @default(true) @map("is_active")
  labelPath    String?  @map("label_path")
  createdAt    DateTime @default(now()) @map("created_at")

  item         Item?       @relation(fields: [itemId], references: [id])
  targetUnit   TargetUnit? @relation(fields: [targetUnitId], references: [id])
  inventoryTxs InventoryTx[]

  @@map("barcode")
}

// ── 재고 트랜잭션 (핵심) ──
model InventoryTx {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now()) @db.Date
  type           String   // 입고 | 출고 | 불출
  itemId         Int      @map("item_id")
  quantity       Int
  unitPrice      Decimal  @default(0) @map("unit_price") @db.Decimal(15, 2)
  currency       String   @default("KRW") // KRW | USD
  amount         Decimal  @default(0) @db.Decimal(15, 2)
  partnerId      Int?     @map("partner_id")
  handlerName    String?  @map("handler_name")
  handlerContact String?  @map("handler_contact")
  memo           String?
  targetUnitId   Int?     @map("target_unit_id")
  refInboundId   Int?     @map("ref_inbound_id")
  barcodeId      Int?     @map("barcode_id")
  location       String?

  // 웨이퍼 속성
  waferResistance String? @map("wafer_resistance")
  waferThickness  String? @map("wafer_thickness")
  waferDirection  String? @map("wafer_direction")
  waferSurface    String? @map("wafer_surface")

  // 감사
  createdBy Int?     @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  item       Item        @relation(fields: [itemId], references: [id])
  partner    Partner?    @relation(fields: [partnerId], references: [id])
  targetUnit TargetUnit? @relation(fields: [targetUnitId], references: [id])
  refInbound InventoryTx? @relation("RefInbound", fields: [refInboundId], references: [id])
  refOutbounds InventoryTx[] @relation("RefInbound")
  barcode    Barcode?    @relation(fields: [barcodeId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])

  @@map("inventory_tx")
}

// ── 타겟 측정 로그 ──
model TargetLog {
  id           Int      @id @default(autoincrement())
  targetUnitId Int      @map("target_unit_id")
  type         String   // 측정 | 폐기 | 상태변경
  weight       Decimal? @db.Decimal(10, 3)
  location     String?
  reason       String?
  userId       Int?     @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  targetUnit TargetUnit @relation(fields: [targetUnitId], references: [id])

  @@map("target_log")
}

// ── 필요수량 ──
model RequiredQty {
  id         Int @id @default(autoincrement())
  itemId     Int @unique @map("item_id")
  quantity   Int @default(0)

  @@map("required_qty")
}

// ── 변경 이력 ──
model AuditLog {
  id         Int      @id @default(autoincrement())
  tableName  String   @map("table_name")
  recordId   Int      @map("record_id")
  action     String   // INSERT | UPDATE | DELETE
  columnName String?  @map("column_name")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  userId     Int?     @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

// ── 출퇴근 ──
model Attendance {
  id       Int       @id @default(autoincrement())
  userId   Int       @map("user_id")
  date     DateTime  @default(now()) @db.Date
  checkIn  DateTime? @map("check_in")
  checkOut DateTime? @map("check_out")
  memo     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

// ── 공지사항 ──
model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  authorId  Int      @map("author_id")
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id])

  @@map("notice")
}
